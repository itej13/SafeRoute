# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional capacity overrides — defaults are free public services with fair-use
# limits. Set these when scaling up (commercial tiles, self-hosted OSRM/Photon).
# VITE_TILE_URL=https://api.maptiler.com/maps/streets-v2/{z}/{x}/{y}.png?key=…
# VITE_TILE_URL_DARK=https://api.maptiler.com/maps/dataviz-dark/{z}/{x}/{y}.png?key=…
# VITE_TILE_ATTRIBUTION=&copy; MapTiler &copy; OpenStreetMap contributors
# VITE_OSRM_URL=https://your-osrm-host/route/v1/foot
# VITE_PHOTON_URL=https://your-photon-host
