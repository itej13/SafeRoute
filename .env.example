# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# data.gov.in — free key from https://www.data.gov.in/user (My Account → API key)
